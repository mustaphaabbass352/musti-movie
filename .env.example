# Get your TMDB API key from https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# Get your Groq API key:
# 1. Go to https://console.groq.com/keys
# 2. Sign up or log in (use Google/email login, no special characters in password)
# 3. Click "Create API Key"
# 4. Copy the key and paste it below
#
# TROUBLESHOOTING:
# - If you get "no cfttoken" error:
#   1. Clear your browser cookies/cache
#   2. Try incognito mode
#   3. Try a different browser
#   4. Wait 1 hour and try again
GROQ_API_KEY=your_groq_api_key_here
